# Firebase project configuration
# Copy this file to .env (which is gitignored) and fill in real values from
# your Firebase console: https://console.firebase.google.com
#
# In CI (GitHub Actions), add these as repository secrets and inject them via
# the workflow's env: block, then use a sed step to replace placeholders in
# src/environments/environment.ts before building.

FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
